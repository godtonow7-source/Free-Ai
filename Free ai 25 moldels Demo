        function useExamplePrompt(el) {
            const text = el.querySelector('.font-medium').textContent.trim()
            document.getElementById('user-input').value = text
            sendMessage()
        }
        
        async function simulateTyping(responseText, messageIndex) {
            const container = document.getElementById('chat-messages')
            const responseContainer = document.getElementById(`response-${messageIndex}`)
            if (!responseContainer) return
            
            responseContainer.innerHTML = ''
            let i = 0
            const speed = 18 // characters per interval
            
            return new Promise(resolve => {
                const interval = setInterval(() => {
                    if (i < responseText.length) {
                        const chunk = responseText.substring(0, i + speed)
                        responseContainer.innerHTML = marked.parse(chunk)
                        hljs.highlightAll()
                        i += speed
                        container.scrollTop = container.scrollHeight
                    } else {
                        clearInterval(interval)
                        responseContainer.innerHTML = marked.parse(responseText)
                        hljs.highlightAll()
                        resolve()
                    }
                }, 8)
            })
        }
        
        async function sendMessage() {
            if (isGenerating) return
            
            const input = document.getElementById('user-input')
            const text = input.value.trim()
            
            if (!text) return
            
            // Add user message
            addMessage('user', text)
            input.value = ''
            
            isGenerating = true
            
            // Add a placeholder assistant message
            const placeholderIndex = messages.length
            messages.push({ 
                role: 'assistant', 
                content: '', 
                timestamp: new Date() 
            })
            renderMessages()
            
            // Simulate network / thinking time
            await new Promise(r => setTimeout(r, 650))
            
            // Get mock response
            const responseText = getMockResponse(text)
            messages[placeholderIndex].content = responseText
            
            // Render with streaming effect
            renderMessages()
            await simulateTyping(responseText, placeholderIndex)
            
            isGenerating = false
        }
        
        function copyResponse(index) {
            const msg = messages[index]
            if (!msg || msg.role !== 'assistant') return
            
            navigator.clipboard.writeText(msg.content).then(() => {
                const originalText = event.currentTarget.innerHTML
                
                event.currentTarget.innerHTML = `
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="4" d="M5 10l7-7m0 0l7 7" />
                    </svg>
                    <span>Kopiert!</span>
                `
                
                setTimeout(() => {
                    event.currentTarget.innerHTML = originalText
                }, 2000)
            })
        }
        
        function newChat() {
            if (confirm('Neuen Chat starten? Der aktuelle Verlauf wird gelöscht.')) {
                messages = []
                renderMessages()
            }
        }
        
        function clearChat() {
