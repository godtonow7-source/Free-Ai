<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>🤖 KI Chat – Kostenlos & Ohne API-Key</title>
  <style>
    :root {
      --bg: #0d0d0f;
      --surface: #18181b;
      --surface2: #1e1e24;
      --border: #2a2a35;
      --accent: #7c3aed;
      --accent2: #a855f7;
      --accent-glow: rgba(124,58,237,0.35);
      --text: #f1f1f3;
      --muted: #8b8b9a;
      --user-bubble: #1d1432;
      --ai-bubble: #141418;
      --error: #ef4444;
      --success: #22c55e;
      --radius: 16px;
      --radius-sm: 10px;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
      height: 100dvh;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* ── HEADER ── */
    header {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 14px 20px;
      display: flex;
      align-items: center;
      gap: 14px;
      flex-wrap: wrap;
      z-index: 10;
    }

    .logo {
      font-size: 1.4rem;
      font-weight: 800;
      background: linear-gradient(135deg, #a855f7, #7c3aed, #4f46e5);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      white-space: nowrap;
    }

    .header-right {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-left: auto;
      flex-wrap: wrap;
    }

    /* Model Switcher */
    .model-tabs {
      display: flex;
      gap: 6px;
      background: var(--surface2);
      padding: 5px;
      border-radius: 12px;
      border: 1px solid var(--border);
    }

    .model-tab {
      padding: 7px 14px;
      border-radius: 8px;
      border: none;
      cursor: pointer;
      font-size: 0.8rem;
      font-weight: 600;
      transition: all 0.2s;
      background: transparent;
      color: var(--muted);
      white-space: nowrap;
    }

    .model-tab:hover { color: var(--text); background: rgba(255,255,255,0.06); }

    .model-tab.active {
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      color: #fff;
      box-shadow: 0 0 14px var(--accent-glow);
    }

    .model-tab .badge {
      display: inline-block;
      font-size: 0.65rem;
      background: rgba(255,255,255,0.15);
      padding: 1px 5px;
      border-radius: 4px;
      margin-left: 4px;
    }

    /* Clear button */
    .btn-clear {
      padding: 8px 14px;
      border-radius: 9px;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--muted);
      cursor: pointer;
      font-size: 0.8rem;
      font-weight: 600;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      gap: 5px;
    }
    .btn-clear:hover { color: var(--error); border-color: var(--error); background: rgba(239,68,68,0.08); }

    /* Lang toggle */
    .lang-btn {
      padding: 7px 12px;
      border-radius: 9px;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--muted);
      cursor: pointer;
      font-size: 0.8rem;
      font-weight: 600;
      transition: all 0.2s;
    }
    .lang-btn:hover { color: var(--text); border-color: var(--accent); }

    /* Model Info Bar */
    .model-info-bar {
      background: var(--surface2);
      border-bottom: 1px solid var(--border);
      padding: 8px 20px;
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 0.78rem;
      color: var(--muted);
    }

    .model-info-bar .dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: var(--success);
      box-shadow: 0 0 6px var(--success);
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%,100% { opacity: 1; }
      50% { opacity: 0.4; }
    }

    .model-info-bar strong { color: var(--text); }

    /* ── CHAT AREA ── */
    #chat-container {
      flex: 1;
      overflow-y: auto;
      padding: 24px 20px;
      display: flex;
      flex-direction: column;
      gap: 18px;
      scrollbar-width: thin;
      scrollbar-color: var(--border) transparent;
    }

    #chat-container::-webkit-scrollbar { width: 5px; }
    #chat-container::-webkit-scrollbar-thumb { background: var(--border); border-radius: 99px; }

    /* Welcome screen */
    .welcome {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      flex: 1;
      gap: 16px;
      text-align: center;
      padding: 40px 20px;
      animation: fadeIn 0.5s ease;
    }

    .welcome-icon {
      width: 80px; height: 80px;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      border-radius: 24px;
      display: flex; align-items: center; justify-content: center;
      font-size: 2.5rem;
      box-shadow: 0 0 30px var(--accent-glow);
    }

    .welcome h2 { font-size: 1.6rem; font-weight: 700; }
    .welcome p { color: var(--muted); max-width: 420px; line-height: 1.6; font-size: 0.92rem; }

    .quick-btns {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      justify-content: center;
      margin-top: 8px;
    }

    .quick-btn {
      padding: 9px 16px;
      border-radius: 99px;
      border: 1px solid var(--border);
      background: var(--surface2);
      color: var(--text);
      cursor: pointer;
      font-size: 0.82rem;
      transition: all 0.2s;
    }
    .quick-btn:hover { border-color: var(--accent); color: var(--accent2); background: rgba(124,58,237,0.1); }

    /* Messages */
    .message {
      display: flex;
      gap: 12px;
      animation: slideUp 0.3s ease;
      max-width: 860px;
      width: 100%;
      margin: 0 auto;
    }

    @keyframes slideUp {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    .message.user { flex-direction: row-reverse; }

    .avatar {
      width: 36px; height: 36px; min-width: 36px;
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.1rem;
      font-weight: 700;
      flex-shrink: 0;
    }

    .avatar.user-av { background: linear-gradient(135deg, #4f46e5, #7c3aed); }
    .avatar.ai-av { background: linear-gradient(135deg, #1e1e2e, #2a2a40); border: 1px solid var(--border); }

    .bubble {
      max-width: calc(100% - 60px);
      padding: 13px 17px;
      border-radius: var(--radius);
      line-height: 1.65;
      font-size: 0.93rem;
      word-break: break-word;
      position: relative;
    }

    .message.user .bubble {
      background: linear-gradient(135deg, var(--user-bubble), #1a1040);
      border: 1px solid rgba(124,58,237,0.3);
      border-radius: var(--radius) var(--radius) 4px var(--radius);
    }

    .message.ai .bubble {
      background: var(--ai-bubble);
      border: 1px solid var(--border);
      border-radius: var(--radius) var(--radius) var(--radius) 4px;
    }

    .bubble-meta {
      font-size: 0.7rem;
      color: var(--muted);
      margin-bottom: 6px;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .bubble-meta .model-tag {
      background: rgba(124,58,237,0.2);
      color: var(--accent2);
      padding: 1px 7px;
      border-radius: 4px;
      font-weight: 600;
      font-size: 0.68rem;
    }

    /* Code blocks */
    .bubble pre {
      background: #0a0a0f;
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 14px;
      overflow-x: auto;
      margin: 10px 0;
      font-size: 0.83rem;
      font-family: 'Cascadia Code', 'Fira Code', 'Consolas', monospace;
      position: relative;
    }

    .bubble code {
      font-family: 'Cascadia Code', 'Fira Code', 'Consolas', monospace;
      font-size: 0.85em;
      background: rgba(124,58,237,0.15);
      padding: 1px 5px;
      border-radius: 4px;
    }

    .bubble pre code { background: none; padding: 0; }

    .copy-code-btn {
      position: absolute;
      top: 8px; right: 8px;
      padding: 3px 9px;
      border-radius: 5px;
      border: 1px solid var(--border);
      background: var(--surface2);
      color: var(--muted);
      cursor: pointer;
      font-size: 0.7rem;
      transition: all 0.2s;
    }
    .copy-code-btn:hover { color: var(--text); border-color: var(--accent); }

    /* Typing indicator */
    .typing-indicator {
      display: flex;
      gap: 5px;
      align-items: center;
      padding: 4px 0;
    }

    .typing-indicator span {
      width: 8px; height: 8px;
      background: var(--accent2);
      border-radius: 50%;
      display: inline-block;
      animation: bounce 1.2s infinite;
    }
    .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
    .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }

    @keyframes bounce {
      0%,60%,100% { transform: translateY(0); }
      30% { transform: translateY(-6px); }
    }

    /* Streaming text */
    .stream-text { white-space: pre-wrap; }

    /* ── INPUT AREA ── */
    .input-area {
      background: var(--surface);
      border-top: 1px solid var(--border);
      padding: 16px 20px;
    }

    .input-wrapper {
      max-width: 860px;
      margin: 0 auto;
      display: flex;
      gap: 10px;
      align-items: flex-end;
      background: var(--surface2);
      border: 1.5px solid var(--border);
      border-radius: var(--radius);
      padding: 10px 14px;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .input-wrapper:focus-within {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-glow);
    }

    #user-input {
      flex: 1;
      background: transparent;
      border: none;
      outline: none;
      color: var(--text);
      font-size: 0.93rem;
      resize: none;
      min-height: 24px;
      max-height: 180px;
      font-family: inherit;
      line-height: 1.5;
      padding: 2px 0;
    }

    #user-input::placeholder { color: var(--muted); }

    #send-btn {
      width: 38px; height: 38px; min-width: 38px;
      border-radius: 10px;
      border: none;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      color: #fff;
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.1rem;
      transition: all 0.2s;
      box-shadow: 0 0 12px var(--accent-glow);
      flex-shrink: 0;
    }

    #send-btn:hover { transform: scale(1.08); box-shadow: 0 0 20px var(--accent-glow); }
    #send-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

    .input-footer {
      max-width: 860px;
      margin: 8px auto 0;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.72rem;
      color: var(--muted);
    }

    .char-count { font-variant-numeric: tabular-nums; }

    /* System prompt toggle */
    .sys-toggle {
      display: flex;
      align-items: center;
      gap: 5px;
      cursor: pointer;
      padding: 2px 8px;
      border-radius: 6px;
      border: 1px solid var(--border);
      transition: all 0.2s;
    }
    .sys-toggle:hover { border-color: var(--accent); color: var(--accent2); }

    /* System prompt panel */
    #sys-panel {
      max-width: 860px;
      margin: 0 auto 10px;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      overflow: hidden;
      display: none;
    }
    #sys-panel.open { display: block; }

    #sys-panel label {
      display: block;
      padding: 8px 12px;
      font-size: 0.75rem;
      color: var(--accent2);
      font-weight: 600;
      border-bottom: 1px solid var(--border);
    }

    #system-prompt {
      width: 100%;
      background: transparent;
      border: none;
      outline: none;
      color: var(--text);
      font-size: 0.84rem;
      padding: 10px 12px;
      resize: vertical;
      min-height: 70px;
      font-family: inherit;
      line-height: 1.5;
    }

    /* Error toast */
    .toast {
      position: fixed;
      bottom: 90px; left: 50%;
      transform: translateX(-50%) translateY(20px);
      background: #1a0a0a;
      border: 1px solid var(--error);
      color: var(--error);
      padding: 10px 20px;
      border-radius: 10px;
      font-size: 0.85rem;
      opacity: 0;
      transition: all 0.3s;
      pointer-events: none;
      z-index: 100;
      white-space: nowrap;
    }
    .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

    /* Scrollbar auto-scroll indicator */
    #scroll-btn {
      position: fixed;
      bottom: 100px; right: 24px;
      width: 38px; height: 38px;
      background: var(--accent);
      border: none;
      border-radius: 50%;
      color: #fff;
      cursor: pointer;
      display: none;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
      box-shadow: 0 4px 14px var(--accent-glow);
      z-index: 50;
      transition: all 0.2s;
    }
    #scroll-btn.show { display: flex; }
    #scroll-btn:hover { transform: scale(1.1); }

    /* Token counter */
    .token-info {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .resp-time {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 0.7rem;
      color: var(--muted);
      margin-top: 6px;
    }

    /* Responsive */
    @media (max-width: 600px) {
      .model-tabs { gap: 4px; }
      .model-tab { padding: 6px 10px; font-size: 0.75rem; }
      .model-tab .badge { display: none; }
      .logo { font-size: 1.1rem; }
    }
  </style>
</head>
<body>

<!-- HEADER -->
<header>
  <div class="logo">🤖 KI Chat</div>

  <div class="model-tabs">
    <button class="model-tab active" data-model="openai" onclick="setModel('openai', this)">
      GPT-4o <span class="badge">Fast</span>
    </button>
    <button class="model-tab" data-model="mistral" onclick="setModel('mistral', this)">
      Mistral <span class="badge">Open</span>
    </button>
    <button class="model-tab" data-model="claude-hybridspace" onclick="setModel('claude-hybridspace', this)">
      Claude <span class="badge">Smart</span>
    </button>
  </div>

  <div class="header-right">
    <button class="lang-btn" onclick="toggleLang()" id="lang-toggle-btn">🌐 EN</button>
    <button class="btn-clear" onclick="clearChat()">🗑️ <span class="clear-label">Leeren</span></button>
  </div>
</header>

<!-- MODEL INFO BAR -->
<div class="model-info-bar">
  <div class="dot"></div>
  <span id="model-desc"><strong>GPT-4o</strong> — Schnell &amp; vielseitig. Powered by Pollinations.ai · 100% kostenlos · kein API-Key</span>
</div>

<!-- SYSTEM PROMPT PANEL -->
<div id="sys-panel">
  <label id="sys-label">⚙️ System-Prompt (Anweisung für die KI)</label>
  <textarea id="system-prompt" placeholder="z.B. Du bist ein hilfreicher Assistent. Antworte immer auf Deutsch..." rows="3"></textarea>
</div>

<!-- CHAT -->
<div id="chat-container">
  <div class="welcome" id="welcome-screen">
    <div class="welcome-icon">🤖</div>
    <h2 id="welcome-title">Wie kann ich dir helfen?</h2>
    <p id="welcome-sub">Wähle ein Modell oben und starte ein Gespräch. Alle Modelle sind kostenlos &amp; kein API-Key nötig.</p>
    <div class="quick-btns">
      <button class="quick-btn" onclick="quickSend('Erkläre mir Machine Learning einfach')">🧠 ML erklären</button>
      <button class="quick-btn" onclick="quickSend('Schreib einen kurzen Python-Code für eine To-Do App')">💻 Code schreiben</button>
      <button class="quick-btn" onclick="quickSend('Was sind die besten KI-Tools in 2025?')">🚀 KI Tools 2025</button>
      <button class="quick-btn" onclick="quickSend('Schreib mir ein kreatives Gedicht über die Zukunft')">✍️ Gedicht schreiben</button>
    </div>
  </div>
</div>

<!-- SCROLL BUTTON -->
<button id="scroll-btn" onclick="scrollToBottom()" title="Nach unten scrollen">↓</button>

<!-- INPUT AREA -->
<div class="input-area">
  <div id="sys-panel"><!-- moved inline above --></div>
  <div class="input-wrapper">
    <textarea
      id="user-input"
      placeholder="Nachricht eingeben... (Enter = Senden, Shift+Enter = Neue Zeile)"
      rows="1"
      oninput="autoResize(this); updateCharCount()"
      onkeydown="handleKey(event)"
    ></textarea>
    <button id="send-btn" onclick="sendMessage()" title="Senden (Enter)">➤</button>
  </div>
  <div class="input-footer">
    <div class="token-info">
      <span class="sys-toggle" onclick="toggleSysPanel()">⚙️ <span id="sys-toggle-txt">System-Prompt</span></span>
    </div>
    <span class="char-count" id="char-count">0 Zeichen</span>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
// ─────────────────────────────────────────────
//  STATE
// ─────────────────────────────────────────────
let currentModel = 'openai';
let messages = [];     // [{role, content}]
let isStreaming = false;
let lang = 'de';

const modelInfo = {
  'openai': {
    name: 'GPT-4o',
    emoji: '⚡',
    de: 'Schnell &amp; vielseitig. Powered by Pollinations.ai · 100% kostenlos · kein API-Key',
    en: 'Fast &amp; versatile. Powered by Pollinations.ai · 100% free · no API key',
  },
  'mistral': {
    name: 'Mistral',
    emoji: '🌪️',
    de: 'Open-Source Powerhouse. Powered by Pollinations.ai · 100% kostenlos · kein API-Key',
    en: 'Open-Source Powerhouse. Powered by Pollinations.ai · 100% free · no API key',
  },
  'claude-hybridspace': {
    name: 'Claude',
    emoji: '🧠',
    de: 'Analytisch &amp; präzise. Powered by Pollinations.ai · 100% kostenlos · kein API-Key',
    en: 'Analytical &amp; precise. Powered by Pollinations.ai · 100% free · no API key',
  }
};

const i18n = {
  de: {
    welcome_title: 'Wie kann ich dir helfen?',
    welcome_sub: 'Wähle ein Modell oben und starte ein Gespräch. Alle Modelle sind kostenlos &amp; kein API-Key nötig.',
    placeholder: 'Nachricht eingeben... (Enter = Senden, Shift+Enter = Neue Zeile)',
    clear_label: 'Leeren',
    sys_label: '⚙️ System-Prompt (Anweisung für die KI)',
    sys_toggle: 'System-Prompt',
    you: 'Du',
    thinking: 'Denkt nach...',
    error_prefix: '⚠️ Fehler:',
    copied: '✅ Kopiert!',
    lang_btn: '🌐 EN',
  },
  en: {
    welcome_title: 'How can I help you?',
    welcome_sub: 'Choose a model above and start chatting. All models are free &amp; no API key needed.',
    placeholder: 'Type a message... (Enter = Send, Shift+Enter = New line)',
    clear_label: 'Clear',
    sys_label: '⚙️ System Prompt (Instruction for the AI)',
    sys_toggle: 'System Prompt',
    you: 'You',
    thinking: 'Thinking...',
    error_prefix: '⚠️ Error:',
    copied: '✅ Copied!',
    lang_btn: '🌐 DE',
  }
};

// ─────────────────────────────────────────────
//  MODEL SWITCHER
// ─────────────────────────────────────────────
function setModel(model, btn) {
  currentModel = model;
  document.querySelectorAll('.model-tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  updateModelBar();
}

function updateModelBar() {
  const info = modelInfo[currentModel];
  const key = lang === 'de' ? 'de' : 'en';
  document.getElementById('model-desc').innerHTML =
    `<strong>${info.name}</strong> — ${info[key]}`;
}

// ─────────────────────────────────────────────
//  LANGUAGE TOGGLE
// ─────────────────────────────────────────────
function toggleLang() {
  lang = lang === 'de' ? 'en' : 'de';
  applyLang();
}

function applyLang() {
  const t = i18n[lang];
  document.getElementById('welcome-title').textContent = t.welcome_title;
  document.getElementById('welcome-sub').innerHTML = t.welcome_sub;
  document.getElementById('user-input').placeholder = t.placeholder;
  document.querySelector('.clear-label').textContent = t.clear_label;
  document.getElementById('sys-label').textContent = t.sys_label.replace('⚙️ ', '⚙️ ');
  document.getElementById('sys-toggle-txt').textContent = t.sys_toggle;
  document.getElementById('lang-toggle-btn').textContent = t.lang_btn;
  updateModelBar();
}

// ─────────────────────────────────────────────
//  SYSTEM PROMPT PANEL
// ─────────────────────────────────────────────
function toggleSysPanel() {
  const panel = document.getElementById('sys-panel');
  panel.classList.toggle('open');
}

// ─────────────────────────────────────────────
//  TEXTAREA AUTO-RESIZE
// ─────────────────────────────────────────────
function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 180) + 'px';
}

function updateCharCount() {
  const val = document.getElementById('user-input').value;
  document.getElementById('char-count').textContent = val.length + (lang === 'de' ? ' Zeichen' : ' chars');
}

// ─────────────────────────────────────────────
//  KEY HANDLER
// ─────────────────────────────────────────────
function handleKey(e) {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMessage();
  }
}

// ─────────────────────────────────────────────
//  QUICK SEND
// ─────────────────────────────────────────────
function quickSend(text) {
  document.getElementById('user-input').value = text;
  sendMessage();
}

// ─────────────────────────────────────────────
//  CLEAR CHAT
// ─────────────────────────────────────────────
function clearChat() {
  messages = [];
  const container = document.getElementById('chat-container');
  container.innerHTML = `
    <div class="welcome" id="welcome-screen">
      <div class="welcome-icon">🤖</div>
