// ─────────────────────────────────────────────
//  SCROLL
// ─────────────────────────────────────────────
function scrollToBottom(smooth = true) {
  const c = document.getElementById('chat-container');
  c.scrollTo({ top: c.scrollHeight, behavior: smooth ? 'smooth' : 'instant' });
}

const chatContainer = document.getElementById('chat-container');
chatContainer.addEventListener('scroll', () => {
  const c = chatContainer;
  const nearBottom = c.scrollHeight - c.scrollTop - c.clientHeight < 120;
  document.getElementById('scroll-btn').classList.toggle('show', !nearBottom && messages.length > 0);
});

// ─────────────────────────────────────────────
//  MARKDOWN RENDERER (lightweight)
// ─────────────────────────────────────────────
function renderMarkdown(text) {
  // Code blocks first
  text = text.replace(/```(\w+)?\n?([\s\S]*?)```/g, (_, lang, code) => {
    const escaped = code.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    return `<pre><button class="copy-code-btn" onclick="copyCode(this)">📋 Copy</button><code>${escaped}</code></pre>`;
  });
  // Inline code
  text = text.replace(/`([^`]+)`/g, '<code>$1</code>');
  // Bold
  text = text.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
  // Italic
  text = text.replace(/\*(.+?)\*/g, '<em>$1</em>');
  // Headers
  text = text.replace(/^### (.+)$/gm, '<h4 style="margin:10px 0 4px;color:#a855f7">$1</h4>');
  text = text.replace(/^## (.+)$/gm, '<h3 style="margin:12px 0 5px;color:#a855f7">$1</h3>');
  text = text.replace(/^# (.+)$/gm, '<h2 style="margin:12px 0 6px;color:#a855f7">$1</h2>');
  // Unordered lists
  text = text.replace(/^\s*[-*•] (.+)$/gm, '<li>$1</li>');
  text = text.replace(/(<li>.*<\/li>(\n|$))+/g, m => `<ul style="padding-left:20px;margin:6px 0">${m}</ul>`);
  // Ordered lists
  text = text.replace(/^\d+\. (.+)$/gm, '<li>$1</li>');
  // Line breaks (but not inside pre)
  text = text.replace(/\n(?!<\/?(pre|ul|li|h[1-6]|ol))/g, '<br>');
  return text;
}

function copyCode(btn) {
  const code = btn.nextElementSibling.textContent;
  navigator.clipboard.writeText(code).then(() => {
    const orig = btn.textContent;
    btn.textContent = i18n[lang].copied;
    setTimeout(() => btn.textContent = orig, 1500);
  });
}

// ─────────────────────────────────────────────
//  ADD MESSAGE TO DOM
// ─────────────────────────────────────────────
function addMessage(role, content, modelName, streaming = false) {
  // Hide welcome screen
  const ws = document.getElementById('welcome-screen');
  if (ws) ws.remove();

  const container = document.getElementById('chat-container');
  const info = modelInfo[currentModel];
  const now = new Date().toLocaleTimeString('de-DE', { hour: '2-digit', minute: '2-digit' });

  const div = document.createElement('div');
  div.className = `message ${role}`;
  div.id = streaming ? 'streaming-msg' : '';

  if (role === 'user') {
    div.innerHTML = `
      <div class="avatar user-av">👤</div>
      <div class="bubble">
        <div class="bubble-meta">${i18n[lang].you} · ${now}</div>
        <div class="stream-text">${content.replace(/</g,'&lt;').replace(/>/g,'&gt;')}</div>
      </div>`;
  } else {
    div.innerHTML = `
      <div class="avatar ai-av">${info ? info.emoji : '🤖'}</div>
      <div class="bubble">
        <div class="bubble-meta">
          <span class="model-tag">${modelName || info?.name || 'AI'}</span>
          · ${now}
        </div>
        <div class="stream-text" id="stream-content">
          ${streaming ? '<div class="typing-indicator"><span></span><span></span><span></span></div>' : renderMarkdown(content)}
        </div>
      </div>`;
  }

  container.appendChild(div);
  scrollToBottom();
  return div;
}

// ─────────────────────────────────────────────
//  SEND MESSAGE
// ─────────────────────────────────────────────
async function sendMessage() {
  if (isStreaming) return;

  const input = document.getElementById('user-input');
  const text = input.value.trim();
  if (!text) return;

  const sysPrompt = document.getElementById('system-prompt').value.trim();

  // Add user message
  addMessage('user', text);
  messages.push({ role: 'user', content: text });

  // Clear input
  input.value = '';
  input.style.height = 'auto';
  updateCharCount();

  // Disable send button
  const sendBtn = document.getElementById('send-btn');
  sendBtn.disabled = true;
  isStreaming = true;

  // Add AI placeholder
  const aiMsgEl = addMessage('ai', '', null, true);
  const streamContent = aiMsgEl.querySelector('#stream-content');

  const startTime = Date.now();
  let fullText = '';

  try {
    // Build messages array for API
    const apiMessages = [];
    if (sysPrompt) {
      apiMessages.push({ role: 'system', content: sysPrompt });
    }
    apiMessages.push(...messages);

    // Call Pollinations.ai streaming API
    const response = await fetch('https://text.pollinations.ai/openai', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: currentModel,
        messages: apiMessages,
        stream: true,
        seed: Math.floor(Math.random() * 99999),
      })
    });

    if (!response.ok) {
      throw new Error(`HTTP ${response.status}: ${response.statusText}`);
    }

    const reader = response.body.getReader();
    const decoder = new TextDecoder();
    let buffer = '';
    let firstChunk = true;

    while (true) {
      const { done, value } = await reader.read();
      if (done) break;

      buffer += decoder.decode(value, { stream: true });
      const lines = buffer.split('\n');
      buffer = lines.pop();

      for (const line of lines) {
        const trimmed = line.trim();
        if (!trimmed || !trimmed.startsWith('data:')) continue;

        const data = trimmed.slice(5).trim();
        if (data === '[DONE]') continue;

        try {
          const parsed = JSON.parse(data);
          const delta = parsed.choices?.[0]?.delta?.content;
          if (delta) {
            if (firstChunk) {
              streamContent.innerHTML = '';
              firstChunk = false;
            }
            fullText += delta;
            streamContent.innerHTML = renderMarkdown(fullText);
            scrollToBottom(false);
          }
        } catch (_) {}
      }
    }

    // If nothing streamed, try non-streaming fallback
    if (!fullText) {
      throw new Error('No content received from stream');
    }

  } catch (err) {
    // Try non-streaming fallback
    try {
      streamContent.innerHTML = '<div class="typing-indicator"><span></span><span></span><span></span></div>';

      const sysPrompt2 = document.getElementById('system-prompt').value.trim();
      const apiMessages2 = [];
      if (sysPrompt2) apiMessages2.push({ role: 'system', content: sysPrompt2 });
      apiMessages2.push(...messages);

      const resp2 = await fetch('https://text.pollinations.ai/openai', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: currentModel,
          messages: apiMessages2,
          stream: false,
          seed: Math.floor(Math.random() * 99999),
        })
      });

      if (!resp2.ok) throw new Error(`HTTP ${resp2.status}`);

      const json = await resp2.json();
      fullText = json.choices?.[0]?.message?.content || '';

      if (!fullText) throw new Error('Empty response');

      streamContent.innerHTML = renderMarkdown(fullText);

    } catch (err2) {
      streamContent.innerHTML = `<span style="color:var(--error)">${i18n[lang].error_prefix} ${err2.message}. Versuche es erneut oder wechsle das Modell.</span>`;
      showToast(`${i18n[lang].error_prefix} ${err2.message}`);
      isStreaming = false;
      sendBtn.disabled = false;
      return;
    }
  }

  // Add response time
  const elapsed = ((Date.now() - startTime) / 1000).toFixed(1);
  const meta = aiMsgEl.querySelector('.bubble-meta');
  if (meta) {
    meta.innerHTML += ` <span class="resp-time">⚡ ${elapsed}s</span>`;
  }

  // Save to history
  messages.push({ role: 'assistant', content: fullText });

  // Re-enable
  isStreaming = false;
  sendBtn.disabled = false;
  aiMsgEl.removeAttribute('id');
  scrollToBottom();
  input.focus();
}

// ─────────────────────────────────────────────
//  TOAST
// ─────────────────────────────────────────────
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3500);
}

