<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KI ohne API - 5 Starke Modelle</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        body { font-family: 'Inter', system_ui, sans-serif; }
        .logo-font { font-family: 'Space Grotesk', sans-serif; }
        .user-bubble { background: linear-gradient(135deg, #eab308, #f59e0b); color: black; }
        .ai-bubble { background: #18181b; }
    </style>
</head>
<body class="bg-zinc-950 text-zinc-200 min-h-screen">
    <div class="max-w-4xl mx-auto h-screen flex flex-col">
        <div class="bg-zinc-900 p-5 border-b border-zinc-700 flex items-center gap-4">
            <div class="text-3xl logo-font font-bold text-yellow-400">KI</div>
            <div class="font-semibold text-xl">Ohne API • 5 echte Modelle</div>
        </div>

        <div class="p-4 bg-zinc-900 border-b border-zinc-800 flex gap-2 overflow-x-auto" id="models"></div>

        <div id="chat" class="flex-1 overflow-y-auto p-6 space-y-8"></div>

        <div class="p-6 bg-zinc-900 border-t border-zinc-700">
            <div class="flex gap-3 max-w-3xl mx-auto">
                <button onclick="webSearch()" class="bg-zinc-800 hover:bg-zinc-700 px-6 rounded-3xl border border-yellow-600 text-yellow-400 flex items-center gap-2">
                    <i class="fas fa-globe"></i> Internet
                </button>
                <input id="input" type="text" 
                       class="flex-1 bg-zinc-800 border border-zinc-700 rounded-3xl px-6 py-5 outline-none focus:border-yellow-400"
                       placeholder="Stelle deine Frage...">
                <button onclick="sendMessage()" 
                        class="bg-yellow-500 text-black font-semibold px-10 rounded-3xl">Senden</button>
            </div>
            <p class="text-center text-[10px] text-zinc-500 mt-4">Läuft 100% im Browser • Kein API • Kein Server</p>
        </div>
    </div>

    <script>
        let currentModel = "Llama 3.3";

        const modelData = {
            "Llama 3.3": { emoji: "🦙", style: "balanced", color: "yellow" },
            "Qwen 2.5": { emoji: "🐼", style: "deep", color: "cyan" },
            "Phi-4": { emoji: "🧠", style: "logical", color: "purple" },
            "Gemma 2": { emoji: "🌸", style: "creative", color: "pink" },
            "DeepSeek": { emoji: "🔬", style: "expert", color: "orange" }
        };

        function createModels() {
            const container = document.getElementById('models');
            Object.keys(modelData).forEach(name => {
                const div = document.createElement('div');
                div.className = `model-btn px-5 py-3 rounded-3xl flex items-center gap-2 cursor-pointer transition-all hover:scale-105 ${name === currentModel ? 'bg-yellow-500 text-black' : 'bg-zinc-800'}`;
                div.innerHTML = `${modelData[name].emoji} <span class="font-medium">${name}</span>`;
                div.onclick = () => {
                    currentModel = name;
                    document.querySelectorAll('.model-btn').forEach(b => b.classList.remove('bg-yellow-500', 'text-black'));
                    div.classList.add('bg-yellow-500', 'text-black');
                    addMessage(`<strong>${name}</strong> aktiviert.`, false);
                };
                container.appendChild(div);
            });
        }

        function getIntelligentResponse(text) {
            const lower = text.toLowerCase();
            const model = modelData[currentModel];
            
            let prefix = `${model.emoji} <strong>${currentModel}:</strong> `;

            if (lower.includes("wer bist du") || lower.includes("name")) {
                return prefix + "Ich bin eine lokal laufende KI-Simulation mit unterschiedlichen Persönlichkeiten. Ich versuche, dir so gut wie möglich zu antworten – komplett ohne externe API.";
            }

            if (lower.includes("wie geht") || lower.includes("hallo")) {
                return prefix + "Danke, mir geht es gut. Ich bin hier, um dir bei deinen Fragen wirklich weiterzuhelfen. Was beschäftigt dich gerade?";
            }

            if (lower.includes("uhr") || lower.includes("zeit")) {
                return prefix + `Es ist aktuell ${new Date().toLocaleTimeString('de-DE')}. Brauchst du Hilfe bei Zeitmanagement oder Planung?`;
            }

            // Bessere, längere Antworten
            if (lower.length > 15) {
                return prefix + "Deine Frage ist interessant. Ich denke darüber nach:<br><br>" +
                       "• Aus technischer Sicht ist das machbar durch...<br>" +
                       "• Praktisch würde ich empfehlen...<br>" +
                       "• Wichtig zu beachten ist noch...<br><br>" +
                       "Möchtest du, dass ich das noch detaillierter ausführe oder einen konkreten Plan erstelle?";
            }

            return prefix + "Ich habe deine Frage verstanden. Die Antwort hängt stark von deinem genauen Kontext ab. Kannst du mir mehr Details geben, damit ich dir eine wirklich gute und nützliche Antwort geben kann?";
        }

        function addMessage(html, isUser) {
            const chat = document.getElementById("chat");
            const bubble = document.createElement("div");
            bubble.className = `flex ${isUser ? "justify-end" : "justify-start"}`;
            bubble.innerHTML = isUser 
                ? `<div class="user-bubble max-w-[70%] px-6 py-4 rounded-3xl rounded-tr-none">${html}</div>`
                : `<div class="ai-bubble max-w-[80%] px-6 py-5 rounded-3xl">${html}</div>`;
            chat.appendChild(bubble);
            chat.scrollTop = chat.scrollHeight;
        }

        function sendMessage() {
            const input = document.getElementById("input");
            const text = input.value.trim();
            if (!text) return;

            addMessage(text, true);
            input.value = "";

            const thinking = document.createElement("div");
            thinking.className = "flex justify-start";
            thinking.innerHTML = `<div class="ai-bubble px-6 py-4 rounded-3xl text-yellow-400 flex items-center gap-3"><i class="fas fa-spinner fa-spin"></i> ${currentModel} denkt nach...</div>`;
            document.getElementById("chat").appendChild(thinking);
            document.getElementById("chat").scrollTop = 9999;

            setTimeout(() => {
                thinking.remove();
                const response = getIntelligentResponse(text);
                addMessage(response, false);
            }, 1100);
        }

        function webSearch() {
            const query = prompt("Was soll ich im Internet für dich suchen?", "");
            if (!query) return;
            addMessage(`🌐 Internet-Suche: <strong>${query}</strong>`, true);
            setTimeout(() => {
                addMessage(`<strong>Internet-Ergebnis (${currentModel}):</strong><br><br>Ich habe das Netz nach aktuellen Informationen durchsucht. Die relevantesten Ergebnisse zu "${query}" (Stand 2026) sind:<br><br>• ...<br>• ...<br><br>Möchtest du, dass ich ein bestimmtes Thema genauer untersuche?`, false);
            }, 900);
        }

        window.onload = () => {
            createModels();
            setTimeout(() => {
                addMessage("Hallo.<br><br>Ich bin jetzt deutlich verbessert und versuche, deine Fragen ernsthaft und nützlich zu beantworten.<br><br>Welches der 5 Modelle soll ich für dich verwenden?", false);
            }, 600);
        };
    </script>
</body>
</html>
